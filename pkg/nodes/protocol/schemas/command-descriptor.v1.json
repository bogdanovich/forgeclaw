{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forgeclaw.dev/schemas/nodes/command-descriptor.v1.json",
  "title": "ForgeClaw node command descriptor v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "capability", "input_schema", "output_schema", "risk"],
  "properties": {
    "name": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)*\\.v[1-9][0-9]*$"},
    "capability": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
    "input_schema": {"type": "object"},
    "output_schema": {"type": "object"},
    "risk": {"enum": ["read", "write", "privileged"]},
    "supports_progress": {"type": "boolean"},
    "supports_cancel": {"type": "boolean"}
  }
}
